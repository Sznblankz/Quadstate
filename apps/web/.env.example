# QuadState cloud config — copy this file to `.env.local` and fill in your
# Supabase project's values. `.env.local` is gitignored; never commit real keys.
#
# Find these in your Supabase dashboard under Settings → API.
# Only VITE_-prefixed vars reach the browser bundle. The anon key is a public,
# RLS-gated key — it is SAFE to ship in a static client. NEVER put the
# service_role key here (it bypasses Row-Level Security).
#
# When unset, the app runs in pure guest mode (local-only, no accounts/sync).

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
