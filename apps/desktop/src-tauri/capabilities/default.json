{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "LogicSim main window: file dialogs + project file IO",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$HOME/**" }, { "path": "$DOCUMENT/**" }, { "path": "$DOWNLOAD/**" }]
    }
  ]
}
