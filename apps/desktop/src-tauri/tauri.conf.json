{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LogicSim",
  "version": "0.1.0",
  "identifier": "com.logicsim.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @logicsim/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @logicsim/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LogicSim",
        "width": 1280,
        "height": 800,
        "minWidth": 700,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
